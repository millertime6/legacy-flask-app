API_TOKEN=replace-with-secure-token
DATABASE_URL=sqlite:///legacy.db
BATCH_EXPORT_DIR=run/exports
SECRET_KEY=replace-with-random-secret
UI_USERNAME=servicing
UI_PASSWORD=change-me
APP_ENV=development
DEBUG=true
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
PORT=5001
# Optional: comma-separated IPs allowed to hit the app (403 otherwise). /health stays open for LBs.
# Behind AWS ALB, set TRUST_PROXY_HEADERS=true (default when APP_ENV=production).
# IP_ALLOWLIST=203.0.113.10
# TRUST_PROXY_HEADERS=true
