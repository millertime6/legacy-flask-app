API_TOKEN=replace-with-secure-token
DATABASE_URL=sqlite:///legacy.db
# PostgreSQL only: libpq sslmode (RDS: usually require; local Docker: prefer or disable)
# DATABASE_SSLMODE=prefer
BATCH_EXPORT_DIR=run/exports
SECRET_KEY=replace-with-random-secret
UI_USERNAME=servicing
UI_PASSWORD=change-me
APP_ENV=development
DEBUG=true
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
PORT=5001
